{
  "name": "@cavaticus/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@cavaticus/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/session": "^11.1.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.40.0",
    "connect-pg-simple": "^10.0.0",
    "drizzle-orm": "^0.39.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "node-fetch": "^3.3.2",
    "octokit": "^3.1.2",
    "pg": "^8.13.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2"
  }
}
