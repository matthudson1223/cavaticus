# Database (auto-injected by Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/cavaticus

# Redis (auto-injected by Railway)
REDIS_URL=redis://localhost:6379

# Session secret (generate: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# AES-256-GCM encryption key for API keys (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Internal URL to the Python agent sidecar
AGENT_SERVICE_URL=http://localhost:8000

# Public API URL (used by the frontend)
VITE_API_URL=http://localhost:8080

# API port
PORT=8080
